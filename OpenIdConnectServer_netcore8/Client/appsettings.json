{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "OpenIDConnectSettings": {
    // OpenID Connect URL. (The base URL for the /.well-known/openid-configuration)
