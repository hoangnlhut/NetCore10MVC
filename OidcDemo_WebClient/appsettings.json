{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "OpenId": {
    // this is https address of OidcDemo_OidcServer project , you can open launchSettings.json of OidcDemo_OidcServer project to find the https address
    "Authority": "https://localhost:7285",
    // ClientId and ClientSecret were setup in client . When it send request to server, it will send with clientId and clientSecret,
    //server will check if the clientId and clientSecret are correct, if correct, server will return access token to client
    "ClientId": "interactive.confidential",
    "ClientSecret": "secret"
    //"Scopes": "api offline_access"
  }
}
